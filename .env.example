# Copy to .env and fill in (for local runs; on GitHub use repo Secrets/Variables)
LLM_PROVIDER=anthropic          # anthropic | openai | deepseek
LLM_API_KEY=sk-...
# LLM_MODEL=                    # optional override
# LLM_BASE_URL=                 # optional, for other OpenAI-compatible providers

SMTP_USER=you@gmail.com
SMTP_PASS=your-gmail-app-password   # https://myaccount.google.com/apppasswords
MAIL_TO=you@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# NOTIFY=email                  # email | telegram | both
# TELEGRAM_BOT_TOKEN=           # from @BotFather
# TELEGRAM_CHAT_ID=             # from /getUpdates after messaging your bot
